@{
    ViewData["Title"] = "Ruta";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>📍 Ruta del Autobús</h2>

<div id="map"></div>

<script src="https://maps.googleapis.com/maps/api/js?key=TU_API_KEY"></script>

<script>
function initMap() {

    var ubicacion = { lat: 18.4861, lng: -69.9312 };

    var map = new google.maps.Map(document.getElementById("map"), {
        zoom: 14,
        center: ubicacion
    });

    new google.maps.Marker({
        position: ubicacion,
        map: map
    });
}

initMap();
</script>

<style>
#map {
    height: 400px;
    margin-top: 20px;
    border-radius: 12px;
}
</style>