@{
    ViewData["Title"] = "Panel de Azafata";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard-header azafata-header">
    <div class="dash-icon">🚌</div>
    <div>
        <h1>Panel de Azafata</h1>
        <p>Autobús asignado: <strong>#@ViewBag.AutobusId</strong></p>
    </div>
</div>

<div class="dash-cards">

    <a asp-controller="Azafata" asp-action="ListaAlumnos" class="dash-card">
        <div class="card-icon">👶</div>
        <div class="card-title">Lista de Alumnos</div>
        <div class="card-desc">Ver estudiantes asignados</div>
    </a>

    <a asp-controller="Azafata" asp-action="Ruta" class="dash-card">
        <div class="card-icon">📍</div>
        <div class="card-title">Ruta del Día</div>
        <div class="card-desc">Ubicación del autobús</div>
    </a>

    <a asp-controller="Azafata" asp-action="Asistencia" class="dash-card">
        <div class="card-icon">📝</div>
        <div class="card-title">Asistencia</div>
        <div class="card-desc">Escanear QR</div>
    </a>

</div>

<style>
    .card-icon {
        font-size: 28px;
        margin-bottom: 8px;
    }

    .card-title {
        font-weight: 600;
        font-size: 16px;
    }

    .card-desc {
        font-size: 13px;
        color: #64748B;
    }

    .dash-card {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 5px;
    }
</style>