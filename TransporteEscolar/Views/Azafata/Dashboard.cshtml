@{
    ViewData["Title"] = "Panel de Azafata";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
.dashboard-container {
    padding: 20px;
}

.dashboard-header {
    display: flex;
    align-items: center;
    gap: 15px;
}

.dash-icon {
    font-size: 40px;
}

.dash-cards {
    display: flex;
    gap: 20px;
    margin-top: 30px;
}

.dash-card {
    flex: 1;
    padding: 25px;
    background: #f5f5f5;
    border-radius: 12px;
    text-align: center;
    font-size: 18px;
    text-decoration: none;
    color: black;
    transition: 0.3s;
    font-weight: bold;
}

.dash-card:hover {
    background: #007bff;
    color: white;
    transform: scale(1.05);
}
</style>

<div class="dashboard-container">
    <div class="dashboard-header">
        <div class="dash-icon">🚌</div>
        <div>
            <h1>Panel de Azafata</h1>
            <p>Autobús asignado: <strong>#@ViewBag.AutobusId</strong></p>
        </div>
    </div>

    <div class="dash-cards">

        <a href="/Azafata/ListaAlumnos" class="dash-card">
            👶 Lista de Alumnos
        </a>

        <a href="/Azafata/Ruta" class="dash-card">
            📍 Ruta del Día
        </a>

        <a href="/Azafata/Asistencia" class="dash-card">
            📝 Registro de Asistencia
        </a>

    </div>
</div>