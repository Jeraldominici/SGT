@model TransporteEscolar.ViewModels.HijoResumenViewModel
@{
    ViewData["Title"] = Model.Alumno.NombreCompleto;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem;">
    <a asp-action="Dashboard" asp-controller="Padre" class="btn-back">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" style="width:16px;height:16px;">
            <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" />
        </svg>
    </a>
    <div>
        <h2 style="font-size:1.375rem; font-weight:700; color:#0F172A; margin:0;">
            @Model.Alumno.NombreCompleto
        </h2>
        <p style="color:#64748B; font-size:.875rem; margin-top:.2rem;">
            @(Model.Alumno.GradoEscolar ?? "Sin grado") — Últimos 30 días
        </p>
    </div>
</div>

<div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
            gap:1.25rem; margin-bottom:1.5rem;">

    <!-- Datos del alumno -->
    <div class="detalle-card">
        <div class="detalle-titulo">👶 Información del Alumno</div>
        <div class="detalle-lista">
            <div class="detalle-fila"><span>Nombre</span><strong>@Model.Alumno.NombreCompleto</strong></div>
            @if (Model.Alumno.FechaNacimiento.HasValue)
            {
            <div class="detalle-fila">
                <span>Nacimiento</span>
                <strong>@Model.Alumno.FechaNacimiento.Value.ToString("dd/MM/yyyy")</strong>
            </div>
            }
            @if (!string.IsNullOrEmpty(Model.Alumno.GradoEscolar))
            {
            <div class="detalle-fila"><span>Grado</span><strong>@Model.Alumno.GradoEscolar</strong></div>
            }
            @if (!string.IsNullOrEmpty(Model.Alumno.NombreTutor))
            {
            <div class="detalle-fila"><span>Tutor</span><strong>@Model.Alumno.NombreTutor</strong></div>
            }
            @if (!string.IsNullOrEmpty(Model.Alumno.TelefonoEmergencia))
            {
            <div class="detalle-fila">
                <span>Tel. Emergencia</span>
                <a href="tel:@Model.Alumno.TelefonoEmergencia"
                   style="color:#2563EB; font-weight:600; text-decoration:none;">
                    @Model.Alumno.TelefonoEmergencia
                </a>
            </div>
            }
            @if (!string.IsNullOrEmpty(Model.Alumno.DireccionRecogida))
            {
            <div class="detalle-fila"><span>Recogida</span><strong>@Model.Alumno.DireccionRecogida</strong></div>
            }
            @if (!string.IsNullOrEmpty(Model.Alumno.DireccionEntrega))
            {
            <div class="detalle-fila"><span>Entrega</span><strong>@Model.Alumno.DireccionEntrega</strong></div>
            }
        </div>
    </div>

    <!-- Datos del autobús -->
    <div class="detalle-card">
        <div class="detalle-titulo">🚌 Autobús</div>
        <div class="detalle-lista">
            <div class="detalle-fila"><span>Ficha</span><strong>@Model.Autobus.Ficha</strong></div>
            @if (!string.IsNullOrEmpty(Model.Autobus.Placa))
            {
            <div class="detalle-fila"><span>Placa</span><strong>@Model.Autobus.Placa</strong></div>
            }
            <div class="detalle-fila"><span>Capacidad</span><strong>@Model.Autobus.Capacidad pasajeros</strong></div>
            <div class="detalle-fila">
                <span>Estado</span>
                @if (Model.Autobus.Activo)
                {
                <span style="background:#F0FDF4; color:#15803D; font-size:.75rem;
                                     font-weight:600; padding:.15rem .5rem; border-radius:20px;">● Activo</span>
                }
                else
                {
                <span style="background:#FEF2F2; color:#DC2626; font-size:.75rem;
                                     font-weight:600; padding:.15rem .5rem; border-radius:20px;">● Inactivo</span>
                }
            </div>
        </div>
    </div>

    <!-- Chofer de hoy -->
    <div class="detalle-card">
        <div class="detalle-titulo">🧑‍✈️ Chofer de Hoy</div>
        @if (Model.JornadaHoy?.Chofer != null)
        {
        <div style="display:flex; align-items:center; gap:.75rem; margin-top:.85rem;">
            <div style="width:46px; height:46px; border-radius:50%; overflow:hidden; flex-shrink:0;
                                background:linear-gradient(135deg,#0369A1,#0891B2);
                                display:flex; align-items:center; justify-content:center;
                                font-size:.9rem; font-weight:700; color:#fff;">
                @if (!string.IsNullOrEmpty(Model.JornadaHoy.Chofer.FotoUrl))
                    {
                <img src="@Model.JornadaHoy.Chofer.FotoUrl"
                     style="width:100%;height:100%;object-fit:cover;" />
                    }
                    else
                    {

                @Model.JornadaHoy.Chofer.NombreCompleto[0]
                    }
            </div>
            <div class="detalle-lista" style="margin:0; flex:1;">
                <div class="detalle-fila">
                    <span>Nombre</span>
                    <strong>@Model.JornadaHoy.Chofer.NombreCompleto</strong>
                </div>
                <div class="detalle-fila">
                    <span>Licencia</span>
                    <strong>@Model.JornadaHoy.Chofer.Licencia</strong>
                </div>
                @if (!string.IsNullOrEmpty(Model.JornadaHoy.Chofer.Telefono))
                    {
                <div class="detalle-fila">
                    <span>Teléfono</span>
                    <a href="tel:@Model.JornadaHoy.Chofer.Telefono"
                       style="color:#2563EB; font-weight:600; text-decoration:none;">
                        @Model.JornadaHoy.Chofer.Telefono
                    </a>
                </div>
                    }
            </div>
        </div>
        }
        else
        {
        <div style="font-size:.875rem; color:#94A3B8; margin-top:.85rem; text-align:center; padding:1rem 0;">
            Sin jornada activa hoy
        </div>
        }
    </div>
</div>

<!-- Historial de asistencia -->
<h3 style="font-size:1rem; font-weight:700; color:#0F172A; margin:0 0 .85rem;">
    📋 Historial de Asistencia (últimos 30 días)
</h3>
<div class="tabla-card" style="margin-bottom:1.5rem;">
    @if (!Model.Asistencias.Any())
    {
    <div style="padding:2rem; text-align:center; color:#94A3B8;">Sin registros de asistencia.</div>
    }
    else
    {
    <table class="tabla-mini">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Ruta</th>
                <th>Estado</th>
                <th>Observación</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Asistencias)
                {
            <tr>
                <td style="font-size:.8125rem; color:#64748B; white-space:nowrap;">
                    @a.Fecha.ToString("dd/MM/yyyy")
                </td>
                <td>
                    <span style="font-size:.8125rem; font-weight:500;">
                        @(a.TipoRuta == "Ida" ? "🌅 Ida" : "🌆 Vuelta")
                    </span>
                </td>
                <td>
                    @if (a.Presente)
                            {
                    <span class="badge-presente">✅ Presente</span>
                            }
                            else
                            {
                    <span class="badge-ausente">❌ Ausente</span>
                            }
                </td>
                <td style="font-size:.8125rem; color:#64748B;">
                    @(a.Observacion ?? "—")
                </td>
            </tr>
                }
        </tbody>
    </table>
    }
</div>

<!-- Incidencias -->
@if (Model.Incidencias.Any())
{
<h3 style="font-size:1rem; font-weight:700; color:#0F172A; margin:0 0 .85rem;">
    ⚠️ Incidencias Registradas
</h3>
<div style="display:flex; flex-direction:column; gap:.75rem;">
    @foreach (var inc in Model.Incidencias)
        {
    <div style="background:#fff; border:1.5px solid #FDE68A; border-radius:10px;
                                padding:1rem 1.25rem; display:flex; gap:.85rem; align-items:flex-start;">
        <span style="font-size:1.25rem; flex-shrink:0;">
            @(inc.Tipo == "Accidente" ? "🚨" :
                                inc.Tipo == "Comportamiento" ? "😤" :
                                inc.Tipo == "Retraso" ? "⏰" : "📌")
        </span>
        <div style="flex:1;">
            <div style="display:flex; align-items:center; gap:.65rem; flex-wrap:wrap;">
                <span style="font-weight:700; color:#0F172A;">@inc.Titulo</span>
                <span style="font-size:.7rem; font-weight:700; padding:.15rem .5rem;
                                     border-radius:20px; text-transform:uppercase;
                                     background:#FEF3C7; color:#D97706;">@inc.Tipo</span>
                                    <span style="font-size:.75rem; color:#94A3B8;">
                                        @inc.Fecha.ToString("dd/MM/yyyy")
                                    </span>
                                </div>
                                <div style="font-size:.875rem; color:#334155; margin-top:.35rem;">
                                    @inc.Descripcion
                                </div>
                            </div>
                        </div>
        }
</div>
}

<style>
    .btn-back {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        background: #fff;
        border: 1.5px solid #E2E8F0;
        border-radius: 8px;
        color: #64748B;
        text-decoration: none;
        transition: all .15s;
        flex-shrink: 0;
    }

        .btn-back:hover {
            border-color: #2563EB;
            color: #2563EB;
            background: #EFF6FF;
        }

    .detalle-card {
        background: #fff;
        border: 1.5px solid #E2E8F0;
        border-radius: 12px;
        padding: 1.1rem 1.25rem;
    }

    .detalle-titulo {
        font-size: .75rem;
        font-weight: 700;
        color: #64748B;
        text-transform: uppercase;
        letter-spacing: .05em;
        margin-bottom: .65rem;
    }

    .detalle-lista {
        display: flex;
        flex-direction: column;
        gap: .45rem;
    }

    .detalle-fila {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: .875rem;
        gap: .5rem;
    }

        .detalle-fila span {
            color: #64748B;
            white-space: nowrap;
        }

        .detalle-fila strong {
            color: #0F172A;
            text-align: right;
        }

    .tabla-card {
        background: #fff;
        border-radius: 12px;
        border: 1.5px solid #E2E8F0;
        overflow-x: auto;
    }

    .tabla-mini {
        width: 100%;
        border-collapse: collapse;
    }

        .tabla-mini thead tr {
            background: #F8FAFC;
            border-bottom: 1.5px solid #E2E8F0;
        }

        .tabla-mini th {
            padding: .65rem 1rem;
            text-align: left;
            font-size: .75rem;
            font-weight: 700;
            color: #64748B;
            text-transform: uppercase;
            letter-spacing: .05em;
            white-space: nowrap;
        }

        .tabla-mini td {
            padding: .75rem 1rem;
            border-bottom: 1px solid #F1F5F9;
            vertical-align: middle;
        }

        .tabla-mini tbody tr:last-child td {
            border-bottom: none;
        }

        .tabla-mini tbody tr:hover {
            background: #F8FAFC;
        }

    .badge-presente {
        background: #F0FDF4;
        color: #15803D;
        font-size: .75rem;
        font-weight: 600;
        padding: .2rem .6rem;
        border-radius: 20px;
    }

    .badge-ausente {
        background: #FEF2F2;
        color: #DC2626;
        font-size: .75rem;
        font-weight: 600;
        padding: .2rem .6rem;
        border-radius: 20px;
    }
</style>