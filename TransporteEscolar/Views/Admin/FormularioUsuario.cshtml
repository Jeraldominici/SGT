@model TransporteEscolar.ViewModels.UsuarioFormViewModel
@{
    ViewData["Title"] = Model.EsEdicion ? "Editar Usuario" : "Nuevo Usuario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="max-width:640px; margin:0 auto;">

    <!-- Encabezado -->
    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.75rem;">
        <a asp-action="Usuarios"
           style="display:flex; align-items:center; justify-content:center;
                  width:36px; height:36px; background:#fff; border:1.5px solid #E2E8F0;
                  border-radius:8px; color:#64748B; text-decoration:none; transition:.15s ease;"
           onmouseover="this.style.borderColor='#2563EB'; this.style.color='#2563EB';"
           onmouseout="this.style.borderColor='#E2E8F0'; this.style.color='#64748B';">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" style="width:16px;height:16px;">
                <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" />
            </svg>
        </a>
        <div>
            <h2 style="font-size:1.25rem; font-weight:700; color:#0F172A; margin:0;">
                @(Model.EsEdicion ? "Editar Usuario" : "Nuevo Usuario")
            </h2>
            <p style="font-size:.8125rem; color:#64748B; margin-top:.15rem;">
                @(Model.EsEdicion ? "Modifica los datos del usuario" : "Completa los datos para crear un nuevo usuario")
            </p>
        </div>
    </div>

    <!-- Tarjeta del formulario -->
    <div style="background:#fff; border:1.5px solid #E2E8F0; border-radius:14px;
                padding:2rem; box-shadow:0 1px 4px rgba(0,0,0,.05);">

        <form asp-action="@(Model.EsEdicion ? "EditarUsuario" : "CrearUsuario")"
              method="post" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UsuarioId" />

            <!-- Nombre de usuario -->
            <div class="fgroup">
                <label asp-for="NombreUsuario" class="flabel">Nombre de Usuario</label>
                <input asp-for="NombreUsuario" class="finput"
                       placeholder="ej. maria.lopez"
                       autocomplete="off" spellcheck="false" />
                <span asp-validation-for="NombreUsuario" class="ferror"></span>
            </div>

            <!-- Nombre completo -->
            <div class="fgroup">
                <label asp-for="NombreCompleto" class="flabel">Nombre Completo</label>
                <input asp-for="NombreCompleto" class="finput"
                       placeholder="ej. María López García" />
                <span asp-validation-for="NombreCompleto" class="ferror"></span>
            </div>

            <!-- Email -->
            <div class="fgroup">
                <label asp-for="Email" class="flabel">
                    Email
                    <span style="font-weight:400; color:#94A3B8; font-size:.7rem; margin-left:.3rem;">(opcional)</span>
                </label>
                <input asp-for="Email" class="finput"
                       placeholder="correo@ejemplo.com"
                       type="email" />
                <span asp-validation-for="Email" class="ferror"></span>
            </div>

            <!-- Contraseña -->
            <div class="fgroup">
                <label asp-for="Password" class="flabel">
                    Contraseña
                    @if (Model.EsEdicion)
                    {
                        <span style="font-weight:400; color:#94A3B8; font-size:.7rem; margin-left:.3rem;">
                            (dejar vacío para no cambiar)
                        </span>
                    }
                </label>
                <input asp-for="Password" class="finput"
                       type="password"
                       placeholder="@(Model.EsEdicion ? "Nueva contraseña (opcional)" : "Mínimo 6 caracteres")"
                       autocomplete="new-password" />
                <span asp-validation-for="Password" class="ferror"></span>
            </div>

            <!-- Confirmar contraseña -->
            <div class="fgroup">
                <label asp-for="ConfirmPassword" class="flabel">Confirmar Contraseña</label>
                <input asp-for="ConfirmPassword" class="finput"
                       type="password"
                       placeholder="Repite la contraseña"
                       autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="ferror"></span>
            </div>

            <!-- Fila: Rol + Autobús -->
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
                <div class="fgroup" style="margin-bottom:0;">
                    <label asp-for="RolId" class="flabel">Rol</label>
                    <select asp-for="RolId" class="finput" id="selectRol">
                        <option value="">— Seleccionar —</option>
                        @foreach (var rol in Model.Roles)
                        {
                            <option value="@rol.RolId">@rol.Nombre</option>
                        }
                    </select>
                    <span asp-validation-for="RolId" class="ferror"></span>
                </div>

                <div class="fgroup" style="margin-bottom:0;" id="groupAutobus">
                    <label asp-for="AutobusId" class="flabel">Autobús Asignado</label>
                    <select asp-for="AutobusId" class="finput">
                        <option value="">— Ninguno —</option>
                        @foreach (var bus in Model.Autobuses)
                        {
                            <option value="@bus.AutobusId">@bus.Ficha — @bus.Placa</option>
                        }
                    </select>
                    <span asp-validation-for="AutobusId" class="ferror"></span>
                </div>
            </div>

            <!-- Activo -->
            <div style="display:flex; align-items:center; gap:.65rem; margin:1.5rem 0 1.75rem;">
                <input asp-for="Activo" type="checkbox" id="chkActivo"
                       style="width:16px; height:16px; accent-color:#2563EB; cursor:pointer;" />
                <label for="chkActivo"
                       style="font-size:.875rem; font-weight:500; color:#334155; cursor:pointer;">
                    Usuario activo
                </label>
            </div>

            <!-- Botones -->
            <div style="display:flex; gap:.75rem; justify-content:flex-end;">
                <a asp-action="Usuarios"
                   style="padding:.6rem 1.25rem; border:1.5px solid #E2E8F0; border-radius:8px;
                          color:#64748B; font-size:.875rem; font-weight:500; text-decoration:none;
                          transition:.15s ease; display:inline-flex; align-items:center;"
                   onmouseover="this.style.borderColor='#94A3B8';"
                   onmouseout="this.style.borderColor='#E2E8F0';">
                    Cancelar
                </a>
                <button type="submit"
                        style="padding:.6rem 1.5rem; background:#2563EB; color:#fff;
                               border:none; border-radius:8px; font-size:.875rem;
                               font-weight:600; cursor:pointer; font-family:'Inter',sans-serif;
                               transition:.15s ease; display:inline-flex; align-items:center; gap:.4rem;"
                        onmouseover="this.style.background='#1D4ED8';"
                        onmouseout="this.style.background='#2563EB';">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" style="width:15px;height:15px;">
                        <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                    </svg>
                    @(Model.EsEdicion ? "Guardar Cambios" : "Crear Usuario")
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .fgroup {
        margin-bottom: 1.1rem;
    }

    .flabel {
        display: block;
        font-size: .8125rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: .35rem;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .finput {
        width: 100%;
        padding: .65rem .9rem;
        border: 1.5px solid #E2E8F0;
        border-radius: 8px;
        font-size: .9375rem;
        font-family: 'Inter', sans-serif;
        color: #0F172A;
        background: #fff;
        outline: none;
        transition: border-color .15s ease, box-shadow .15s ease;
    }

        .finput:focus {
            border-color: #2563EB;
            box-shadow: 0 0 0 3px rgba(37,99,235,.1);
        }

    select.finput {
        cursor: pointer;
    }

    .ferror {
        display: block;
        font-size: .8rem;
        color: #DC2626;
        margin-top: .25rem;
        font-weight: 500;
    }
</style>

<script>
    // Mostrar/ocultar selector de autobús según el rol seleccionado
    (function () {
        const selectRol   = document.getElementById('selectRol');
        const groupAutobus = document.getElementById('groupAutobus');

        function actualizarAutobus() {
            const textoRol = selectRol.options[selectRol.selectedIndex]?.text ?? '';
            groupAutobus.style.opacity  = textoRol === 'Azafata' ? '1' : '0.4';
            groupAutobus.style.pointerEvents = textoRol === 'Azafata' ? 'auto' : 'none';
        }

        selectRol.addEventListener('change', actualizarAutobus);
        actualizarAutobus(); // ejecutar al cargar
    })();
</script>
