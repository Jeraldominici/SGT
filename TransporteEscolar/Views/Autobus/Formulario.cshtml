﻿@model TransporteEscolar.ViewModels.AutobusFormViewModel
@{
    ViewData["Title"] = Model.EsEdicion ? "Editar Autobús" : "Nuevo Autobús";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="max-width:520px; margin:0 auto;">

    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.75rem;">
        <a asp-action="Index" asp-controller="Autobus" class="btn-back">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                 style="width:16px;height:16px;">
                <path fill-rule="evenodd"
                      d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z"
                      clip-rule="evenodd" />
            </svg>
        </a>
        <div>
            <h2 style="font-size:1.25rem; font-weight:700; color:#0F172A; margin:0;">
                @(Model.EsEdicion ? "Editar Autobús" : "Nuevo Autobús")
            </h2>
            <p style="font-size:.8125rem; color:#64748B; margin-top:.15rem;">
                @(Model.EsEdicion ? "Modifica los datos del autobús" : "Registra un nuevo autobús en el sistema")
            </p>
        </div>
    </div>

    <div style="background:#fff; border:1.5px solid #E2E8F0; border-radius:14px;
                padding:2rem; box-shadow:0 1px 4px rgba(0,0,0,.05);">

        <form asp-action="@(Model.EsEdicion ? "Editar" : "Crear")"
              asp-controller="Autobus" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="AutobusId" />

            <!-- Ficha -->
            <div class="fgroup">
                <label asp-for="Ficha" class="flabel">Ficha del Autobús</label>
                <input asp-for="Ficha" class="finput"
                       placeholder="ej. A-001"
                       autocomplete="off"
                       style="text-transform:uppercase;" />
                <span asp-validation-for="Ficha" class="ferror"></span>
                <span class="fhint">Identificador único del autobús. Ej: A-001, B-002</span>
            </div>

            <!-- Placa -->
            <div class="fgroup">
                <label asp-for="Placa" class="flabel">Placa</label>
                <input asp-for="Placa" class="finput"
                       placeholder="ej. ABC-1234"
                       autocomplete="off"
                       style="text-transform:uppercase;" />
                <span asp-validation-for="Placa" class="ferror"></span>
            </div>

            <!-- Capacidad -->
            <div class="fgroup">
                <label asp-for="Capacidad" class="flabel">
                    Capacidad
                    <span id="capacidadValor"
                          style="font-weight:700; color:#2563EB; margin-left:.4rem;">
                        @Model.Capacidad pasajeros
                    </span>
                </label>
                <input asp-for="Capacidad" type="range"
                       min="1" max="100" step="1"
                       class="finput-range"
                       id="capacidadRange"
                       oninput="document.getElementById('capacidadValor').textContent = this.value + ' pasajeros';
                                document.getElementById('capacidadNum').value = this.value;" />
                <input type="number" id="capacidadNum"
                       value="@Model.Capacidad" min="1" max="100"
                       class="finput" style="margin-top:.5rem; width:120px;"
                       oninput="document.getElementById('capacidadRange').value = this.value;
                                document.getElementById('capacidadValor').textContent = this.value + ' pasajeros';" />
                <span asp-validation-for="Capacidad" class="ferror"></span>
            </div>

            <!-- Activo -->
            <div style="display:flex; align-items:center; gap:.65rem; margin:1.25rem 0 1.75rem;">
                <input asp-for="Activo" type="checkbox" id="chkActivo"
                       style="width:16px; height:16px; accent-color:#2563EB; cursor:pointer;" />
                <label for="chkActivo"
                       style="font-size:.875rem; font-weight:500; color:#334155; cursor:pointer;">
                    Autobús activo en el sistema
                </label>
            </div>

            <!-- Botones -->
            <div style="display:flex; gap:.75rem; justify-content:flex-end;">
                <a asp-action="Index" asp-controller="Autobus"
                   style="padding:.6rem 1.25rem; border:1.5px solid #E2E8F0; border-radius:8px;
                          color:#64748B; font-size:.875rem; font-weight:500; text-decoration:none;
                          display:inline-flex; align-items:center; transition:.15s ease;"
                   onmouseover="this.style.borderColor='#94A3B8';"
                   onmouseout="this.style.borderColor='#E2E8F0';">
                    Cancelar
                </a>
                <button type="submit"
                        style="padding:.6rem 1.5rem; background:#2563EB; color:#fff;
                               border:none; border-radius:8px; font-size:.875rem; font-weight:600;
                               cursor:pointer; font-family:'Inter',sans-serif; transition:.15s ease;
                               display:inline-flex; align-items:center; gap:.4rem;"
                        onmouseover="this.style.background='#1D4ED8';"
                        onmouseout="this.style.background='#2563EB';">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                         style="width:15px;height:15px;">
                        <path fill-rule="evenodd"
                              d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z"
                              clip-rule="evenodd" />
                    </svg>
                    @(Model.EsEdicion ? "Guardar Cambios" : "Crear Autobús")
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .fgroup {
        margin-bottom: 1.1rem;
    }

    .flabel {
        display: block;
        font-size: .8125rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: .35rem;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .finput {
        width: 100%;
        padding: .65rem .9rem;
        border: 1.5px solid #E2E8F0;
        border-radius: 8px;
        font-size: .9375rem;
        font-family: 'Inter', sans-serif;
        color: #0F172A;
        background: #fff;
        outline: none;
        transition: border-color .15s, box-shadow .15s;
    }

        .finput:focus {
            border-color: #2563EB;
            box-shadow: 0 0 0 3px rgba(37,99,235,.1);
        }

    .finput-range {
        width: 100%;
        accent-color: #2563EB;
        cursor: pointer;
        height: 6px;
        margin-top: .4rem;
    }

    .ferror {
        display: block;
        font-size: .8rem;
        color: #DC2626;
        margin-top: .25rem;
        font-weight: 500;
    }

    .fhint {
        display: block;
        font-size: .75rem;
        color: #94A3B8;
        margin-top: .25rem;
    }

    .btn-back {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        background: #fff;
        border: 1.5px solid #E2E8F0;
        border-radius: 8px;
        color: #64748B;
        text-decoration: none;
        transition: all .15s ease;
        flex-shrink: 0;
    }

        .btn-back:hover {
            border-color: #2563EB;
            color: #2563EB;
            background: #EFF6FF;
        }
</style>