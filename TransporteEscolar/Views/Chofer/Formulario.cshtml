@model TransporteEscolar.ViewModels.ChoferFormViewModel
@{
    ViewData["Title"] = Model.EsEdicion ? "Editar Chofer" : "Nuevo Chofer";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="max-width:580px; margin:0 auto;">
    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.75rem;">
        <a asp-action="Index" asp-controller="Chofer" class="btn-back">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" style="width:16px;height:16px;">
                <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" />
            </svg>
        </a>
        <div>
            <h2 style="font-size:1.25rem; font-weight:700; color:#0F172A; margin:0;">
                @(Model.EsEdicion ? "Editar Chofer" : "Nuevo Chofer")
            </h2>
            <p style="font-size:.8125rem; color:#64748B; margin-top:.15rem;">
                @(Model.EsEdicion ? "Modifica los datos del chofer" : "Registra un nuevo chofer en el sistema")
            </p>
        </div>
    </div>

    <div style="background:#fff; border:1.5px solid #E2E8F0; border-radius:14px;
        padding:2rem; box-shadow:0 1px 4px rgba(0,0,0,.05);">

        <form asp-action="@(Model.EsEdicion ? "Editar" : "Crear")"
              asp-controller="Chofer" method="post"
              enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ChoferId" />
            <input type="hidden" asp-for="FotoUrlActual" />

            <!-- Foto actual + upload -->
            <div class="fgroup" style="text-align:center; margin-bottom:1.5rem;">
                <div id="fotoPreview" style="width:90px; height:90px; border-radius:50%;
                    margin:0 auto .75rem; overflow:hidden; border:3px solid #E2E8F0;
                    background:linear-gradient(135deg,#0369A1,#0891B2);
                    display:flex; align-items:center; justify-content:center;">
                    @if (!string.IsNullOrEmpty(Model.FotoUrlActual))
                    {
                        <img id="fotoImg" src="@Model.FotoUrlActual"
                             style="width:100%; height:100%; object-fit:cover;" />
                    }
                    else
                    {
                        <span style="font-size:2rem; color:#fff;">👤</span>
                    }
                </div>
                <label for="FotoArchivo"
                       style="display:inline-flex; align-items:center; gap:.35rem;
                    padding:.4rem .9rem; border:1.5px solid #E2E8F0; border-radius:7px;
                    font-size:.8125rem; font-weight:500; color:#64748B; cursor:pointer;
                    transition:.15s ease;"
                       onmouseover="this.style.borderColor='#2563EB'; this.style.color='#2563EB';"
                       onmouseout="this.style.borderColor='#E2E8F0'; this.style.color='#64748B';">
                    📷 @(string.IsNullOrEmpty(Model.FotoUrlActual) ? "Subir foto" : "Cambiar foto")
                </label>
                <input type="file" id="FotoArchivo" name="FotoArchivo"
                       accept="image/*" style="display:none;"
                       onchange="previewFoto(this)" />
            </div>

            <!-- Nombre completo -->
            <div class="fgroup">
                <label asp-for="NombreCompleto" class="flabel">Nombre Completo</label>
                <input asp-for="NombreCompleto" class="finput" placeholder="ej. Roberto Martínez López" />
                <span asp-validation-for="NombreCompleto" class="ferror"></span>
            </div>

            <!-- DUI y Licencia -->
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
                <div class="fgroup">
                    <label asp-for="DUI" class="flabel">DUI / Cédula</label>
                    <input asp-for="DUI" class="finput" placeholder="01234567-8" />
                    <span asp-validation-for="DUI" class="ferror"></span>
                </div>
                <div class="fgroup">
                    <label asp-for="Licencia" class="flabel">Licencia de Conducir</label>
                    <input asp-for="Licencia" class="finput" placeholder="L-001234" />
                    <span asp-validation-for="Licencia" class="ferror"></span>
                </div>
            </div>

            <!-- Teléfono -->
            <div class="fgroup">
                <label asp-for="Telefono" class="flabel">
                    Teléfono
                    <span style="font-weight:400; color:#94A3B8; font-size:.7rem; margin-left:.3rem;">(opcional)</span>
                </label>
                <input asp-for="Telefono" class="finput" placeholder="7801-2345" type="tel" />
                <span asp-validation-for="Telefono" class="ferror"></span>
            </div>

            <!-- Activo -->
            <div style="display:flex; align-items:center; gap:.65rem; margin:1.25rem 0 1.75rem;">
                <input asp-for="Activo" type="checkbox" id="chkActivo"
                       style="width:16px; height:16px; accent-color:#2563EB; cursor:pointer;" />
                <label for="chkActivo"
                       style="font-size:.875rem; font-weight:500; color:#334155; cursor:pointer;">
                    Chofer activo en el sistema
                </label>
            </div>

            <!-- Botones -->
            <div style="display:flex; gap:.75rem; justify-content:flex-end;">
                <a asp-action="Index" asp-controller="Chofer"
                       style="padding:.6rem 1.25rem; border:1.5px solid #E2E8F0; border-radius:8px;
                    color:#64748B; font-size:.875rem; font-weight:500; text-decoration:none;
                    display:inline-flex; align-items:center; transition:.15s;"
                       onmouseover="this.style.borderColor='#94A3B8';"
                       onmouseout="this.style.borderColor='#E2E8F0';">
                    Cancelar
                </a>
                <button type="submit"
                        style="padding:.6rem 1.5rem; background:#2563EB; color:#fff; border:none;
                    border-radius:8px; font-size:.875rem; font-weight:600; cursor:pointer;
                    font-family:'Inter',sans-serif; transition:.15s; display:inline-flex;
                    align-items:center; gap:.4rem;"
                        onmouseover="this.style.background='#1D4ED8';"
                        onmouseout="this.style.background='#2563EB';">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" style="width:15px;height:15px;">
                        <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                    </svg>
                    @(Model.EsEdicion ? "Guardar Cambios" : "Crear Chofer")
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .fgroup {
        margin-bottom: 1.1rem;
    }

    .flabel {
        display: block;
        font-size: .8125rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: .35rem;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .finput {
        width: 100%;
        padding: .65rem .9rem;
        border: 1.5px solid #E2E8F0;
        border-radius: 8px;
        font-size: .9375rem;
        font-family: 'Inter',sans-serif;
        color: #0F172A;
        background: #fff;
        outline: none;
        transition: border-color .15s, box-shadow .15s;
    }

        .finput:focus {
            border-color: #2563EB;
            box-shadow: 0 0 0 3px rgba(37,99,235,.1);
        }

    .ferror {
        display: block;
        font-size: .8rem;
        color: #DC2626;
        margin-top: .25rem;
        font-weight: 500;
    }

    .btn-back {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        background: #fff;
        border: 1.5px solid #E2E8F0;
        border-radius: 8px;
        color: #64748B;
        text-decoration: none;
        transition: all .15s ease;
        flex-shrink: 0;
    }

        .btn-back:hover {
            border-color: #2563EB;
            color: #2563EB;
            background: #EFF6FF;
        }
</style>

<script>
    function previewFoto(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                const preview = document.getElementById('fotoPreview');
                preview.innerHTML = `<img src="${e.target.result}"
                    style="width:100%; height:100%; object-fit:cover;" />`;
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>